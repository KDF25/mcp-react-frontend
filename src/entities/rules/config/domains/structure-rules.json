{
  "model": {
    "baseMaxSize": 3,
    "requiredFiles": [
      "index.ts",
      "types.ts"
    ],
    "subfolders": [
      "config",
      "schema",
      "types",
      "api",
      "converters"
    ],
    "filePattern": "^[a-z0-9-]+\\.(config|types|schema|converters|service)\\.ts$"
  },
  "entities": {
    "requiredFolders": [
      "api",
      "types",
      "schema",
      "converters",
      "ui"
    ],
    "naming": {
      "schema": "*.schema.ts",
      "converters": "*.converters.ts",
      "api": "*.service.ts"
    }
  },
  "converters": {
    "suffix": ".converters.ts",
    "mandatory": true,
    "requiredMethods": [
      "mapToFrontend",
      "mapToBackend"
    ]
  }
}
