{
  "fsd": {
    "layers": [
      "app",
      "pages",
      "widgets",
      "features",
      "entities",
      "shared"
    ],
    "boundaries": [
      {
        "from": "entities",
        "allow": [
          "shared"
        ]
      },
      {
        "from": "features",
        "allow": [
          "entities",
          "shared",
          "features"
        ]
      },
      {
        "from": "widgets",
        "allow": [
          "features",
          "entities",
          "shared"
        ]
      },
      {
        "from": "pages",
        "allow": [
          "widgets",
          "features",
          "entities",
          "shared"
        ]
      },
      {
        "from": "app",
        "allow": [
          "pages",
          "widgets",
          "features",
          "entities",
          "shared"
        ]
      }
    ],
    "rules": {
      "no-cross-layer-imports": true,
      "enforce-directory-structure": true,
      "no-private-imports": true,
      "enforce-barrel-exports": true
    }
  },
  "naming": {
    "fileCase": "kebab-case",
    "prefixes": {
      "interface": "I",
      "type": "T",
      "enum": "ENUM_"
    },
    "backend": {
      "typeSuffix": "Backend",
      "fileSuffix": "-backend",
      "interfaceExtension": ".interface.ts"
    },
    "exclusions": {
      "hooks": "^use[A-Z]",
      "nextjs": [
        "page",
        "layout",
        "loading",
        "error",
        "not-found",
        "template",
        "default"
      ]
    },
    "suffixes": {
      "schema": ".schema.ts",
      "converters": ".converters.ts",
      "api": ".service.ts",
      "handlers": ".handlers.ts",
      "mock": ".mock.ts",
      "config": ".config.ts"
    }
  },
  "linter": {
    "noConsole": true,
    "noAny": true,
    "strictTyping": true,
    "noEnums": true
  },
  "structure": {
    "model": {
      "baseMaxSize": 3,
      "requiredFiles": [
        "index.ts",
        "types.ts"
      ],
      "subfolders": [
        "config",
        "schema",
        "types",
        "api",
        "converters"
      ],
      "filePattern": "^[a-z0-9-]+\\.(config|types|schema|converters|service)\\.ts$"
    },
    "entities": {
      "requiredFolders": [
        "api",
        "types",
        "schema",
        "converters",
        "ui"
      ],
      "naming": {
        "schema": "*.schema.ts",
        "converters": "*.converters.ts",
        "api": "*.service.ts"
      }
    },
    "converters": {
      "suffix": ".converters.ts",
      "mandatory": true,
      "requiredMethods": [
        "mapToFrontend",
        "mapToBackend"
      ]
    }
  },
  "styles": {
    "allowedUtilityPrefixes": [
      "bg-",
      "text-",
      "border-",
      "p-",
      "m-",
      "gap-",
      "flex-",
      "grid-"
    ],
    "forbiddenColors": [
      "slate",
      "gray",
      "zinc",
      "neutral",
      "stone",
      "red",
      "orange",
      "amber",
      "yellow",
      "lime",
      "green",
      "emerald",
      "teal",
      "cyan",
      "sky",
      "blue",
      "indigo",
      "violet",
      "purple",
      "fuchsia",
      "pink",
      "rose"
    ],
    "requiredUtility": "cn"
  },
  "patterns": {
    "stateManagement": {
      "server": "RTK Query (base.api.ts)",
      "client": "Redux Toolkit (slices)",
      "local": "useState"
    },
    "rtkQuery": {
      "location": "src/entities/[entity-name]/api",
      "requiredFiles": [
        "index.ts",
        "*.service.ts"
      ],
      "locationRequiredFiles": {
        "tagsConfig": "src/shared/api/backend/tags.config.ts",
        "baseApi": "src/shared/api/backend/base.api.ts",
        "backendIndex": "src/shared/api/backend/index.ts",
        "authBaseQuery": "src/entities/auth/api/auth-base-query.ts",
        "authApi": "src/entities/auth/api/auth.api.ts",
        "authIndex": "src/entities/auth/api/index.ts",
        "service": "src/entities/[entity-name]/api/[entity-name].service.ts",
        "serviceIndex": "src/entities/[entity-name]/api/index.ts"
      },
      "template": "src/entities/rules/config/entities/api-pattern.md",
      "description": "Паттерн работы с RTK Query: Code Splitting через injectEndpoints, централизованные теги и семантическое переименование в UI.",
      "segments": [
        "Base API",
        "Injected Endpoints",
        "Automatic Selectors"
      ]
    },
    "ui": {
      "composition": {
        "widgets": [
          "features",
          "entities"
        ]
      },
      "responsibility": {
        "entities": "presentation",
        "features": "interactivity"
      }
    },
    "i18n": {
      "location": "src/shared/config/i18n",
      "requiredFiles": [
        "index.ts",
        "i18n.init.ts",
        "i18n.config.ts",
        "i18n.blocks.ts",
        "i18n.types.ts",
        "i18n-key.ts",
        "change-language.ts",
        "i18n.checker.ts"
      ],
      "template": "src/entities/rules/config/i18n-pattern.md",
      "description": "Строгая система интернализации с типизацией ключей и проверкой соответствия языков. Полные шаблоны файлов доступны в @template."
    },
    "converters": {
      "location": "src/entities/[entity-name]/converters",
      "requiredFiles": [
        "index.ts",
        "*.converters.ts"
      ],
      "locationRequiredFiles": {
        "converters": "src/entities/[entity-name]/converters/[entity-name].converters.ts",
        "types": "src/entities/[entity-name]/types/[entity-name].backend.interface.ts"
      },
      "template": "src/entities/rules/config/entities/converters-pattern.md",
      "description": "Паттерн маппинга DTO в Domain модели. Обязательное использование в transformResponse и подготовке body запросов."
    },
    "msw": {
      "location": "src/entities/[entity-name]/handlers",
      "requiredFiles": [
        "index.ts",
        "*.handlers.ts"
      ],
      "locationRequiredFiles": {
        "init": "src/app/init/msw.ts",
        "browser": "src/shared/api/msw/browser.ts",
        "handlers": "src/entities/[entity-name]/handlers/[entity-name].handlers.ts",
        "handlersIndex": "src/entities/[entity-name]/handlers/index.ts",
        "mock": "src/entities/[entity-name]/mock/[entity-name].mock.ts",
        "mockIndex": "src/entities/[entity-name]/mock/index.ts"
      },
      "template": "src/entities/rules/config/entities/msw-pattern.md",
      "description": "Паттерн макетирования API через MSW. Обязательная регистрация хендлеров в сетапе воркера и использование переменных окружения для контроля запуска."
    },
    "theme": {
      "location": "src/app/providers/theme",
      "requiredFiles": [
        "index.ts",
        "theme.provider.tsx",
        "with-theme.tsx"
      ],
      "locationRequiredFiles": {
        "provider": "src/app/providers/theme/theme.provider.tsx",
        "providerIndex": "src/app/providers/theme/index.ts",
        "toggle": "src/shared/ui/layout/theme-toggle/ui/theme-toggle.tsx",
        "toggleIndex": "src/shared/ui/layout/theme-toggle/index.ts",
        "context": "src/shared/ui/layout/theme-toggle/model/theme.context.ts",
        "hook": "src/shared/ui/layout/theme-toggle/model/useTheme.tsx"
      },
      "template": "src/entities/rules/config/entities/theme-pattern.md",
      "description": "Паттерн переключения тем (Light/Dark). Обязательное использование ThemeProvider и useTheme для управления состоянием и синхронизации с DOM."
    },
    "styles": {
      "location": "src/shared/styles",
      "requiredFiles": [
        "global.css",
        "variables.css",
        "theme.css"
      ],
      "locationRequiredFiles": {
        "global": "src/shared/styles/global.css",
        "variables": "src/shared/styles/variables.css",
        "theme": "src/shared/styles/theme.css",
        "config": "tailwind.config.ts"
      },
      "template": "src/entities/rules/config/entities/styles-pattern.md",
      "description": "Паттерн работы с дизайн-токенами и Tailwind CSS. Строгий запрет на хардкод цветов и использование стандартных палитр Tailwind."
    },
    "zod": {
      "location": "src/entities/[entity-name]/schema",
      "requiredFiles": [
        "index.ts",
        "*.schema.ts"
      ],
      "locationRequiredFiles": {
        "schema": "src/entities/[entity-name]/schema/[entity-name].schema.ts",
        "types": "src/entities/[entity-name]/types/[entity-name].types.ts"
      },
      "template": "src/entities/rules/config/entities/zod-pattern.md",
      "description": "Паттерн валидации данных через Zod. Обязательное использование типизированных ключей i18n и генерация типов через z.infer."
    }
  }
}